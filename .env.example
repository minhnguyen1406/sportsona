# Copy to .env and fill in real values for your environment.
# .env is gitignored; .env.example is committed as documentation.

# --- Database ---
# When running the backend in Docker, point at the compose service name:
#   POSTGRES_SERVER=sportsona-db
# When running uvicorn / pytest / alembic on the host, use:
#   POSTGRES_SERVER=localhost
POSTGRES_SERVER=sportsona-db
POSTGRES_USER=sportsona_user
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=sportsona

# --- JWT ---
# Generate a strong secret in production: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
# Must be at least 32 bytes for HS256 (PyJWT will warn otherwise).
SECRET_KEY=dev-secret-key-change-in-production-please
ALGORITHM=HS256
# 7 days = 60 * 24 * 7 = 10080
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- FastF1 ---
# Where FastF1 caches downloaded session data. /app/cache is the in-container
# path mounted from a docker volume; on the host you can use ./cache or any
# writable directory.
FASTF1_CACHE_DIR=/app/cache

# --- Anthropic / Race recaps ---
# Required for the personalized race-recap feature. Get a key from
# https://console.anthropic.com/. Leave blank to disable recap generation.
ANTHROPIC_API_KEY=
# Default model. Override to e.g. claude-sonnet-4-6 to trade quality for cost.
RECAP_MODEL=claude-opus-4-7
